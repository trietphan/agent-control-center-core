# This file is a reference; the app does not load it automatically. Export the
# values in every daemon, worker, CLI, and MCP process that must share state.

# Local state and artifact root. Prefer an absolute path when multiple processes
# start from different working directories. Defaults to ./.acc.
ACC_HOME=.acc

# Worker lease settings. Active workers heartbeat; a new worker blocks stale
# executions for explicit operator recovery instead of silently rerunning them.
ACC_WORKER_HEARTBEAT_MS=15000
ACC_WORKER_STALE_AFTER_MS=300000

# Authenticated loopback daemon used by API and MCP clients.
ACC_DAEMON_URL=http://127.0.0.1:4317
# Optional explicit token sources. By default both clients read
# ACC_HOME/daemon.token. Never commit either value.
# ACC_DAEMON_TOKEN_FILE=/absolute/path/to/.acc/daemon.token
# ACC_DAEMON_TOKEN=

# Optional browser origins for a separately installed local UI, encoded as a
# JSON string array. Never expose the local bearer or daemon to a remote page.
# ACC_ALLOWED_ORIGINS='["http://127.0.0.1:3000"]'

# Optional CLI binary overrides. Readiness still requires successful auth probes.
ACC_CODEX_COMMAND=codex
ACC_CLAUDE_COMMAND=claude

# Optional OpenClaw implementation of the shared adapter HTTP contract.
OPENCLAW_ADAPTER_URL=
OPENCLAW_ADAPTER_TOKEN=

# Optional extra CLI arguments, encoded as a JSON string array.
# ACC_CODEX_ARGS='["--model","<provider-model>"]'
# ACC_CLAUDE_ARGS='["--model","<provider-model>"]'
