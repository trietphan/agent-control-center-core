{
  "name": "agent-control-center-core",
  "version": "0.1.0-alpha.1",
  "description": "Open protocol, adapter SDK, and local execution kernel for evidence-gated agent work.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trietphan/agent-control-center-core.git"
  },
  "bugs": {
    "url": "https://github.com/trietphan/agent-control-center-core/issues"
  },
  "homepage": "https://github.com/trietphan/agent-control-center-core#readme",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || ^24.0.0"
  },
  "bin": {
    "acc": "dist/src/cli.js",
    "acc-adapter-conformance": "dist/src/adapters/conformance-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./accp": {
      "types": "./dist/src/accp/index.d.ts",
      "import": "./dist/src/accp/index.js"
    },
    "./adapter-sdk": {
      "types": "./dist/src/adapters/sdk.d.ts",
      "import": "./dist/src/adapters/sdk.js"
    },
    "./conformance": {
      "types": "./dist/src/adapters/conformance.d.ts",
      "import": "./dist/src/adapters/conformance.js"
    },
    "./kernel": {
      "types": "./dist/src/kernel/index.d.ts",
      "import": "./dist/src/kernel/index.js"
    },
    "./mcp": {
      "types": "./dist/src/mcp.d.ts",
      "import": "./dist/src/mcp.js"
    },
    "./node": {
      "types": "./dist/src/node/index.d.ts",
      "import": "./dist/src/node/index.js"
    }
  },
  "files": [
    "dist/",
    "protocol/",
    "examples/",
    "docs/",
    ".env.example",
    "EXPORT-INVENTORY.json",
    "DCO",
    "LICENSE",
    "NOTICE",
    "*.md",
    "third-party-licenses.generated.json"
  ],
  "scripts": {
    "build": "node tooling/clean.mjs && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node tooling/run-tests.mjs",
    "acc": "tsx src/cli.ts",
    "mcp": "tsx src/cli.ts mcp",
    "generate:protocol": "tsx tooling/generate-protocol-artifacts.ts",
    "generate:protocol:check": "tsx tooling/generate-protocol-artifacts.ts --check",
    "demo:verified-outcome": "tsx tooling/verified-outcome-demo.ts",
    "conformance": "tsx src/adapters/conformance-cli.ts",
    "conformance:fixture": "tsx src/adapters/conformance-cli.ts --command node --arg examples/echo-adapter.mjs",
    "license:check": "node tooling/license-policy.mjs",
    "license:report": "node tooling/generate-third-party-notices.mjs",
    "license:report:check": "node tooling/generate-third-party-notices.mjs --check",
    "deps:refresh-evidence": "npm run license:report && npm run inventory:generate",
    "sbom": "cyclonedx-npm --output-file sbom.cdx.json --output-format JSON --spec-version 1.6 --omit dev",
    "security:secrets": "node tooling/secret-scan.mjs",
    "actions:pin-check": "node tooling/check-action-pins.mjs",
    "inventory:generate": "node tooling/generate-file-inventory.mjs",
    "inventory:check": "node tooling/generate-file-inventory.mjs --check",
    "check": "npm run generate:protocol:check && npm run inventory:check && npm run typecheck && npm run build && npm test && npm run conformance:fixture && npm run demo:verified-outcome && npm run license:check && npm run license:report:check && npm run actions:pin-check",
    "prepack": "npm run check && npm run license:report",
    "prepublishOnly": "node tooling/assert-publication-approved.mjs && npm run check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "commander": "13.1.0",
    "sqlite": "5.1.1",
    "sqlite3": "6.0.1",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "6.0.0",
    "@types/node": "22.20.1",
    "@types/ws": "8.18.1",
    "license-checker-rseidelsohn": "5.0.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": false,
    "libxmljs2@0.37.0": true,
    "sqlite3@6.0.1": true
  }
}
